# String de conexão do Postgres do Supabase, usando a app_backend_role
# criada em schema-banco-dados.sql (NUNCA a service_role).
# Use a connection string do "Transaction pooler" (porta 6543) do
# Supabase, adicionando ?pgbouncer=true no final — necessário para
# evitar problemas de prepared statements do Prisma com o PgBouncer.
DATABASE_URL="postgresql://app_backend_role:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

JWT_SECRET="troque-por-um-segredo-bem-grande-e-aleatorio"
JWT_EXPIRES_IN="8h"

# Motor de IA (RAG + agente)
OPENAI_API_KEY="sk-..."
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Usada para cifrar as credenciais da Evolution API guardadas no banco.
# Gere uma com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATIONS_ENCRYPTION_KEY="cole-aqui-64-caracteres-hex"

PORT=3001
CORS_ORIGIN="http://localhost:3000"
